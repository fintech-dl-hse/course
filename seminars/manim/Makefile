SHELL := /bin/bash

.PHONY: venv render sample lint test clean

SCENE ?= RNNUnroll
VIDEO ?=

# Override with e.g. `make venv PYTHON=/path/to/python3.12`.
# Auto-probe: caller override -> homebrew 3.12 -> homebrew 3.11 -> python3.12/11/10 on PATH -> python3.
PYTHON ?=

venv:
	@set -euo pipefail; \
	echo "[venv] Probing ffmpeg..."; \
	if command -v ffmpeg >/dev/null 2>&1; then \
		FFMPEG_OK=1; FFMPEG_PREPEND=""; \
	elif test -x "$$HOME/homebrew/bin/ffmpeg"; then \
		FFMPEG_OK=1; FFMPEG_PREPEND="$$HOME/homebrew/bin"; \
		echo "[venv] Using user-local ffmpeg at $$HOME/homebrew/bin/ffmpeg"; \
	else \
		echo "[venv] ERROR: ffmpeg not found on PATH and not at \$$HOME/homebrew/bin/ffmpeg. Install ffmpeg first."; \
		exit 1; \
	fi; \
	echo "[venv] Probing latex..."; \
	if command -v latex >/dev/null 2>&1; then \
		LATEX_OK=1; LATEX_PREPEND=""; \
	elif test -x /usr/local/texlive/2024/bin/universal-darwin/latex; then \
		LATEX_OK=1; LATEX_PREPEND="/usr/local/texlive/2024/bin/universal-darwin"; \
		echo "[venv] Using MacTeX at /usr/local/texlive/2024/bin/universal-darwin/latex"; \
	else \
		echo "[venv] ERROR: latex not found on PATH and not at /usr/local/texlive/2024/bin/universal-darwin/latex. Install MacTeX."; \
		exit 1; \
	fi; \
	echo "[venv] Probing Python (>=3.10, <3.13 preferred for ManimCE/pycairo)..."; \
	PY=""; \
	if [ -n "$(PYTHON)" ]; then PY="$(PYTHON)"; fi; \
	for cand in "$$HOME/homebrew/bin/python3.12" "$$HOME/homebrew/bin/python3.11" "$$HOME/homebrew/bin/python3.10" python3.12 python3.11 python3.10; do \
		if [ -z "$$PY" ] && command -v "$$cand" >/dev/null 2>&1; then PY="$$cand"; fi; \
	done; \
	if [ -z "$$PY" ]; then \
		echo "[venv] ERROR: no Python 3.10/3.11/3.12 found. Install one or pass PYTHON=/path/to/python3.12"; \
		exit 1; \
	fi; \
	PY_VER=$$("$$PY" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")'); \
	case "$$PY_VER" in \
		3.10|3.11|3.12) echo "[venv] Using Python $$PY_VER at $$PY";; \
		*) echo "[venv] ERROR: Python $$PY_VER is out of range (need 3.10-3.12)"; exit 1;; \
	esac; \
	echo "[venv] Probing pkg-config / cairo (needed by pycairo)..."; \
	BREW_PKGCFG=""; \
	if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists cairo 2>/dev/null; then \
		echo "[venv] system pkg-config finds cairo"; \
	elif test -x "$$HOME/homebrew/bin/pkg-config" && test -f "$$HOME/homebrew/lib/pkgconfig/cairo.pc"; then \
		BREW_PKGCFG="$$HOME/homebrew/lib/pkgconfig"; \
		echo "[venv] Using user-local pkg-config + cairo (.pc at $$BREW_PKGCFG)"; \
	else \
		echo "[venv] ERROR: pkg-config + cairo unavailable. Install via brew: cairo, pango, pkgconf."; \
		exit 1; \
	fi; \
	mkdir -p bin; \
	{ \
		echo '#!/usr/bin/env bash'; \
		echo '# Generated by `make venv`. Source to prepend user-local ffmpeg/latex/pkg-config to PATH.'; \
		echo '# Safe to source multiple times.'; \
		if [ -n "$$FFMPEG_PREPEND" ]; then \
			echo "if ! command -v ffmpeg >/dev/null 2>&1; then export PATH=\"$$FFMPEG_PREPEND:\$$PATH\"; fi"; \
		fi; \
		if [ -n "$$LATEX_PREPEND" ]; then \
			echo "if ! command -v latex >/dev/null 2>&1; then export PATH=\"$$LATEX_PREPEND:\$$PATH\"; fi"; \
		fi; \
		if [ -n "$$BREW_PKGCFG" ]; then \
			echo "if ! command -v pkg-config >/dev/null 2>&1; then export PATH=\"$$HOME/homebrew/bin:\$$PATH\"; fi"; \
			echo "export PKG_CONFIG_PATH=\"$$BREW_PKGCFG:\$${PKG_CONFIG_PATH:-}\""; \
		fi; \
	} > bin/activate_env.sh; \
	chmod +x bin/activate_env.sh; \
	echo "[venv] Wrote bin/activate_env.sh"; \
	if [ ! -d .venv ]; then \
		echo "[venv] Creating .venv with $$PY"; \
		"$$PY" -m venv .venv; \
	fi; \
	source bin/activate_env.sh 2>/dev/null || true; \
	.venv/bin/pip install --upgrade pip; \
	.venv/bin/pip install -r requirements.txt; \
	echo "[venv] Smoke-checking ManimCE..."; \
	.venv/bin/manim --version 2>&1 | grep -qi 'manim community' || { echo "[venv] ERROR: ManimCE not installed correctly"; exit 1; }; \
	echo "[venv] OK"

render:
	@set -euo pipefail; \
	source bin/activate_env.sh 2>/dev/null || true; \
	SCENE_FILE=$$(find scenes -name '$(SCENE).py' -type f 2>/dev/null | head -n1); \
	if [ -z "$$SCENE_FILE" ]; then \
		SCENE_FILE=$$(grep -Rl --include='*.py' -E '^class[[:space:]]+$(SCENE)[[:space:]]*\(' scenes 2>/dev/null | head -n1); \
	fi; \
	if [ -z "$$SCENE_FILE" ]; then \
		echo "[render] ERROR: no file matching scenes/**/$(SCENE).py and no class $(SCENE) in scenes/**/*.py"; \
		exit 1; \
	fi; \
	echo "[render] SCENE_FILE=$$SCENE_FILE"; \
	mkdir -p .out; \
	PYTHONPATH="$$PWD:$${PYTHONPATH:-}" .venv/bin/manim --media_dir .out/media -qm "$$SCENE_FILE" $(SCENE); \
	STEM=$$(basename "$$SCENE_FILE" .py); \
	SRC=$$(find .out/media/videos/$$STEM -name '$(SCENE).mp4' -type f | head -n1); \
	if [ -z "$$SRC" ]; then \
		echo "[render] ERROR: could not locate rendered $(SCENE).mp4 under .out/media/videos/$$STEM/"; \
		exit 1; \
	fi; \
	mv "$$SRC" .out/$(SCENE).mp4; \
	echo "[render] wrote .out/$(SCENE).mp4"

sample:
	@set -euo pipefail; \
	source bin/activate_env.sh 2>/dev/null || true; \
	if [ -z "$(VIDEO)" ]; then \
		echo "[sample] ERROR: pass VIDEO=<path>"; \
		exit 1; \
	fi; \
	.venv/bin/python scripts/sample_frames.py $(VIDEO)

lint:
	@set -euo pipefail; \
	source bin/activate_env.sh 2>/dev/null || true; \
	if [ -z "$(SCENE)" ]; then \
		echo "[lint] ERROR: pass SCENE=<ClassName>"; \
		exit 1; \
	fi; \
	PYTHONPATH="$$PWD:$${PYTHONPATH:-}" .venv/bin/python scripts/lint_scene.py --scene $(SCENE)

test:
	@set -euo pipefail; \
	source bin/activate_env.sh 2>/dev/null || true; \
	PYTHONPATH="$$PWD:$${PYTHONPATH:-}" .venv/bin/python -m pytest tests/ $(PYTEST_ARGS)

clean:
	rm -rf .out/
